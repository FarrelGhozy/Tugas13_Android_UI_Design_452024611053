<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Tugas13UI" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorPrimaryContainer">@color/primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/onPrimaryContainer</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        <item name="colorSecondaryContainer">@color/secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/onSecondaryContainer</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/onTertiary</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/onBackground</item>
        <item name="colorOnSurface">@color/onSurface</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/onSurfaceVariant</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/onError</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primaryDark</item>

        <!-- Text appearance defaults (all sp) -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.Tugas13.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Tugas13.Headline2</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.Tugas13.Headline3</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.Tugas13.Headline4</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.Tugas13.Headline5</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Tugas13.Headline6</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Tugas13.Subtitle1</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.Tugas13.Subtitle2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Tugas13.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Tugas13.Body2</item>
        <item name="textAppearanceButton">@style/TextAppearance.Tugas13.Button</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Tugas13.Caption</item>
        <item name="textAppearanceOverline">@style/TextAppearance.Tugas13.Overline</item>
    </style>
</resources>
