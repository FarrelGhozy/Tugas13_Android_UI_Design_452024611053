<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        ============================================================
        TYPE SCALE — Sistem Tipografi Terpadu
        ============================================================
        Seluruh ukuran menggunakan SATUAN sp (scale-independent pixels)
        agar otomatis menyesuaikan preferensi font size pengguna.

        Type Scale mengikuti rekomendasi Material Design:
        Headline 1–6 → Untuk judul (bold, besar)
        Subtitle 1–2 → Untuk sub-judul
        Body 1–2     → Untuk konten paragraf
        Button       → Untuk teks tombol (ALL CAPS by default)
        Caption      → Untuk teks kecil (bantuan, timestamp)
        Overline     → Untuk label kecil di atas konten (ALL CAPS)
    -->

    <!-- Headlines -->
    <style name="TextAppearance.Tugas13.Headline1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textSize">96sp</item>
        <item name="android:letterSpacing">-0.015</item>
        <item name="android:fontWeight">300</item>
    </style>

    <style name="TextAppearance.Tugas13.Headline2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textSize">60sp</item>
        <item name="android:letterSpacing">-0.005</item>
        <item name="android:fontWeight">300</item>
    </style>

    <style name="TextAppearance.Tugas13.Headline3" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">48sp</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="TextAppearance.Tugas13.Headline4" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">0.0025</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="TextAppearance.Tugas13.Headline5" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">24sp</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="TextAppearance.Tugas13.Headline6" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">0.0015</item>
        <item name="android:fontWeight">500</item>
    </style>

    <!-- Subtitles -->
    <style name="TextAppearance.Tugas13.Subtitle1" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.0015</item>
        <item name="android:fontWeight">400</item>
    </style>

    <style name="TextAppearance.Tugas13.Subtitle2" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.001</item>
        <item name="android:fontWeight">500</item>
    </style>

    <!-- Body -->
    <style name="TextAppearance.Tugas13.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.005</item>
        <item name="android:fontWeight">400</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="TextAppearance.Tugas13.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.0025</item>
        <item name="android:fontWeight">400</item>
        <item name="android:lineSpacingExtra">2sp</item>
    </style>

    <!-- Button -->
    <style name="TextAppearance.Tugas13.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.0125</item>
        <item name="android:fontWeight">500</item>
        <item name="textAllCaps">true</item>
    </style>

    <!-- Caption -->
    <style name="TextAppearance.Tugas13.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.004</item>
        <item name="android:fontWeight">400</item>
    </style>

    <!-- Overline -->
    <style name="TextAppearance.Tugas13.Overline" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textSize">10sp</item>
        <item name="android:letterSpacing">0.015</item>
        <item name="android:fontWeight">400</item>
        <item name="textAllCaps">true</item>
    </style>
</resources>
